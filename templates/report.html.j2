<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ICS-ZoneAudit Report</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            /* Professional Industrial Dark Theme */
            --bg-base: #1e1e1e;
            --bg-surface: #252526;
            --bg-elevated: #2d2d30;
            
            --text-main: #cccccc;
            --text-muted: #999999;
            --text-heading: #ffffff;
            
            --accent-primary: #007acc;
            
            /* Severity Colors - Muted */
            --high-color: #f48771;
            --high-bg: rgba(244, 135, 113, 0.1);
            --medium-color: #cca700;
            --medium-bg: rgba(204, 167, 0, 0.1);
            --low-color: #89d185;
            --low-bg: rgba(137, 209, 133, 0.1);
            
            --border-color: #3e3e42;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-base);
            color: var(--text-main);
            line-height: 1.5;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 2px solid var(--border-color);
        }

        .header-title h1 {
            font-size: 2rem;
            font-weight: 600;
            color: var(--text-heading);
            margin-bottom: 0.25rem;
            letter-spacing: -0.5px;
        }

        .header-title p {
            color: var(--text-muted);
            font-size: 1rem;
        }

        .header-meta {
            text-align: right;
            font-family: 'JetBrains Mono', Consolas, monospace;
            font-size: 0.9rem;
            color: var(--text-muted);
            background: var(--bg-surface);
            padding: 0.5rem 1rem;
            border: 1px solid var(--border-color);
        }

        /* Panels */
        .panel {
            background: var(--bg-surface);
            border: 1px solid var(--border-color);
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .panel-title {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--text-heading);
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid var(--border-color);
        }

        /* Dashboard Grid */
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: var(--bg-elevated);
            border: 1px solid var(--border-color);
            padding: 1.25rem;
            text-align: left;
            border-left: 4px solid var(--accent-primary);
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 600;
            color: var(--text-heading);
            font-family: 'JetBrains Mono', Consolas, monospace;
            margin-bottom: 0.25rem;
        }

        .stat-label {
            color: var(--text-muted);
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Badges */
        .badge {
            display: inline-flex;
            align-items: center;
            padding: 0.15rem 0.5rem;
            font-size: 0.8rem;
            font-weight: 600;
            border-radius: 2px;
            text-transform: uppercase;
        }

        .badge-high { color: var(--high-color); background: var(--high-bg); border: 1px solid var(--high-color); }
        .badge-medium { color: var(--medium-color); background: var(--medium-bg); border: 1px solid var(--medium-color); }
        .badge-low { color: var(--low-color); background: var(--low-bg); border: 1px solid var(--low-color); }

        /* Tables */
        .table-wrapper {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
            font-size: 0.95rem;
        }

        th {
            padding: 0.75rem 1rem;
            color: var(--text-heading);
            font-weight: 600;
            border-bottom: 2px solid var(--border-color);
            background: var(--bg-elevated);
        }

        td {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--border-color);
            vertical-align: top;
        }

        tbody tr:nth-child(even) {
            background: rgba(255, 255, 255, 0.02);
        }

        .code-font {
            font-family: 'JetBrains Mono', Consolas, monospace;
            font-size: 0.9rem;
            color: #d4d4d4;
        }

        .violation-desc {
            color: var(--text-main);
            margin-bottom: 0.5rem;
        }

        .violation-ref {
            font-size: 0.85rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* Topology Container */
        .topology-container {
            width: 100%;
            height: 500px;
            background: var(--bg-elevated);
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            border: 1px solid var(--border-color);
        }

        svg {
            width: 100%;
            height: 100%;
            /* No drop shadow for a flatter, technical look */
        }

        /* Asset Scorecards */
        .scorecard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 1rem;
            margin-bottom: 3rem;
        }

        .scorecard {
            background: var(--bg-surface);
            border: 1px solid var(--border-color);
            padding: 1.25rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .scorecard-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 0.75rem;
        }

        .asset-ip {
            font-size: 1.15rem;
            font-weight: 600;
            font-family: 'JetBrains Mono', Consolas, monospace;
            color: var(--text-heading);
        }

        .asset-host {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-top: 0.25rem;
        }

        .asset-score {
            font-size: 1.25rem;
            font-weight: 700;
            padding: 0.15rem 0.5rem;
            border: 1px solid var(--border-color);
            background: var(--bg-elevated);
        }

        .score-perfect { color: var(--low-color); border-color: var(--low-color); }
        .score-good { color: var(--medium-color); border-color: var(--medium-color); }
        .score-bad { color: var(--high-color); border-color: var(--high-color); }

        .asset-meta {
            display: flex;
            gap: 0.5rem;
        }

        .ports-list {
            font-family: 'JetBrains Mono', Consolas, monospace;
            font-size: 0.85rem;
            color: var(--text-muted);
            background: var(--bg-elevated);
            padding: 0.5rem;
            border: 1px solid var(--border-color);
        }

        .checks-list {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            margin-top: 0.25rem;
        }

        .check-item {
            display: flex;
            gap: 0.5rem;
            align-items: flex-start;
            font-size: 0.85rem;
            padding: 0.35rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }
        
        .check-item:last-child {
            border-bottom: none;
        }

        .check-status {
            font-weight: bold;
            font-size: 0.9rem;
        }

        .check-pass { color: var(--low-color); }
        .check-fail { color: var(--high-color); }

        .check-name {
            font-weight: 500;
            color: var(--text-main);
        }

        .check-error {
            color: var(--high-color);
            font-size: 0.8rem;
            margin-top: 0.15rem;
        }

    </style>
</head>
<body>
    <div class="container">
        <header>
            <div class="header-title">
                <h1>ICS-ZoneAudit</h1>
                <p>IEC 62443 Compliance & Topology Report</p>
            </div>
            <div class="header-meta">
                <div>Target: {{ scan_metadata.target }}</div>
                <div>Hosts Scanned: {{ scan_metadata.total_hosts }}</div>
            </div>
        </header>

        <!-- Zone Summary Dashboard -->
        <div class="dashboard-grid">
            <div class="stat-card">
                <div class="stat-value" style="color: #60a5fa;">{{ zone_summary.get('Enterprise', 0) }}</div>
                <div class="stat-label">Enterprise Assets</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" style="color: #a78bfa;">{{ zone_summary.get('DMZ', 0) }}</div>
                <div class="stat-label">DMZ Assets</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" style="color: #fb923c;">{{ zone_summary.get('Control', 0) }}</div>
                <div class="stat-label">Control Assets</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" style="color: #34d399;">{{ zone_summary.get('Field Device', 0) }}</div>
                <div class="stat-label">Field Devices</div>
            </div>
        </div>

        <!-- Discovered Topology Map -->
        <div class="panel">
            <h2 class="panel-title">Inferred Zone Topology</h2>
            <div class="topology-container">
                {{ svg_diagram | safe }}
            </div>
        </div>

        <!-- Violations Table -->
        <div class="panel">
            <h2 class="panel-title">Zone & Conduit Violations ({{ violations|length }})</h2>
            {% if violations %}
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Severity</th>
                            <th>Type / Description</th>
                            <th>Affected Assets</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for v in violations %}
                        <tr>
                            <td class="code-font">{{ v.violation_id }}</td>
                            <td>
                                <span class="badge badge-{{ v.severity|lower }}">{{ v.severity }}</span>
                            </td>
                            <td>
                                <div style="font-weight: 600; margin-bottom: 0.25rem;">{{ v.type }}</div>
                                <div class="violation-desc">{{ v.description }}</div>
                                <div class="violation-ref">[REF] {{ v.iec_reference }}</div>
                            </td>
                            <td class="code-font">
                                {% for ip in v.affected_assets %}
                                    <div>{{ ip }}</div>
                                {% endfor %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <div style="text-align: center; padding: 3rem; color: var(--text-muted);">
                <div style="font-size: 3rem; margin-bottom: 1rem;">[ OK ]</div>
                <h3>No Violations Detected</h3>
                <p>The analyzed network complies with IEC 62443 zone boundary and conduit rules.</p>
            </div>
            {% endif %}
        </div>
        
        <!-- Asset Scorecards -->
        <h2 class="panel-title" style="margin-top: 3rem;">Detailed Asset Scorecards</h2>
        <div class="scorecard-grid">
            {% for asset in assets %}
            <div class="scorecard">
                <div class="scorecard-header">
                    <div>
                        <div class="asset-ip">{{ asset.ip }}</div>
                        <div class="asset-host">{{ asset.hostname or 'Unknown Host' }} | {{ asset.os_match }}</div>
                    </div>
                    <div class="asset-score {% if asset.score == asset.max_score %}score-perfect{% elif asset.score >= 10 %}score-good{% else %}score-bad{% endif %}">
                        {{ asset.score }}/{{ asset.max_score }}
                    </div>
                </div>
                
                <div class="asset-meta">
                    <span class="badge badge-low">{{ asset.zone }}</span>
                    <span class="badge" style="background: rgba(255,255,255,0.1);">{{ asset.sl }}</span>
                </div>
                
                <div class="ports-list">
                    <strong>Open Ports:</strong> 
                    {% if asset.open_ports %}
                        {{ asset.open_ports|join(', ') }}
                    {% else %}
                        None detected
                    {% endif %}
                </div>
                
                <div class="checks-list">
                    {% for check_id, check in asset.checks.items() %}
                    <div class="check-item">
                        <div class="check-status {% if check.passed %}check-pass{% else %}check-fail{% endif %}">
                            {% if check.passed %}[PASS]{% else %}[FAIL]{% endif %}
                        </div>
                        <div class="check-details">
                            <div class="check-name">{{ check.name }}</div>
                            {% if not check.passed %}
                            <div class="check-error">{{ check.details }}</div>
                            {% endif %}
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </div>

    </div>
</body>
</html>
